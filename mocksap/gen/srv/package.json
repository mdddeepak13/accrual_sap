    "@cap-js/cds-types": "^0.16.0",
    "@sap/cds-dk": "^9",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^6.0.0"
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "dependencies": {
    "@sap/cds": "^9",
    "@cap-js/sqlite": "^2.4.0"
  },
  "scripts": {
    "start": "cds-serve"
