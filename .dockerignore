# Local virtualenvs + caches
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# Local databases
*.db
*.db-journal

# Secrets (set on Fly via `fly secrets set`)
.env
.env.local

# The whole Next.js frontend — not part of the Python image
web/

# Tests: exclude test code but keep fixtures (MOCK_MODE loads from tests/fixtures/)
tests/test_*.py
tests/__init__.py
tests/__pycache__/

# Docs — not needed at runtime
docs/

# Git + OS cruft
.git/
.gitignore
.DS_Store
.vscode/
.idea/

# Build artifacts
dist/
build/
*.egg-info/
