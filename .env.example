# =============================================================================
# Accrual pipeline configuration. Copy to .env and fill in your keys.
# .env is gitignored — never commit real credentials.
# =============================================================================

# --- Required secrets --------------------------------------------------------

# SAP Business Accelerator Hub API key.
# Get one at https://api.sap.com (free, one key covers all sandbox APIs).
SAP_API_KEY=your_sap_api_key_here

# Anthropic API key.
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# --- Claude settings ---------------------------------------------------------

# Model ID. Use claude-sonnet-4-6 for dev iteration (cheaper/faster),
# switch to claude-opus-4-7 for production runs.
CLAUDE_MODEL=claude-sonnet-4-6

# Max output tokens. 4096 is enough for typical batches; bump to 8192 for
# large datasets that trigger many tool_use blocks in one response.
CLAUDE_MAX_TOKENS=4096


# --- Pipeline behavior -------------------------------------------------------

# When true, the FI/MM/CO fetchers return fixture JSON from tests/fixtures/
# instead of calling the SAP sandbox. Claude calls are NEVER mocked — the
# real SDK always runs so prompt iteration is meaningful.
MOCK_MODE=true

# SAP sandbox base URL. Rarely changes.
SAP_SANDBOX_BASE_URL=https://sandbox.api.sap.com


# --- Persistence -------------------------------------------------------------

# SQLAlchemy database URL. SQLite file for local dev; swap to HANA for prod.
DATABASE_URL=sqlite:///./accrual.db


# --- Observability -----------------------------------------------------------

# Structured log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
